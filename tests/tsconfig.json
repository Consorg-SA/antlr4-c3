{
    "compilerOptions": {
        "declaration": true,
        "module": "ES2020",
        "target": "ES2020",
        "moduleResolution": "node",
        "noEmit": false,
        "emitDeclarationOnly": true,
        "removeComments": false,
        "noImplicitAny": true,
        // "noImplicitOverride": false,
        "sourceMap": true,
        "inlineSources": true,
        "isolatedModules": false,
        "allowSyntheticDefaultImports": false,
        "strictNullChecks": true,
        "stripInternal": true
    },
    "include": [
        "**/*.ts",
    ],
    "exclude": [
        "node_modules",
        "lib/**/*",
        "src/**/*"
    ]
}
